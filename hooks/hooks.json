{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/install.js\"",
            "async": false
          }
        ],
        "description": "Install alcove binary if missing (cross-platform), register MCP server"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "alcove reap",
            "async": true
          }
        ],
        "description": "Reap orphaned alcove stdio proxy processes"
      }
    ]
  }
}

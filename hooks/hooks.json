{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/setup.sh\"",
            "async": true
          }
        ],
        "description": "Auto-install alcove binary if missing, register MCP server"
      }
    ]
  }
}
